# .env.local — ChainCapsule Environment Variables
# Copy this file and fill in your values before running.
# DO NOT commit this file to git.

# ── Tatum ─────────────────────────────────────────────────────────────
# Get your free API key at https://tatum.io
NEXT_PUBLIC_TATUM_KEY=your_tatum_api_key_here

# ── Sui Network ────────────────────────────────────────────────────────
# Use "testnet" during development, "mainnet" for final submission
NEXT_PUBLIC_SUI_NETWORK=testnet

# ── Smart Contract ────────────────────────────────────────────────────
# Fill in after running: sui client publish --gas-budget 100000000
NEXT_PUBLIC_PACKAGE_ID=0x_YOUR_PACKAGE_ID_HERE

# ── Sui Clock (shared object — same on all networks) ──────────────────
NEXT_PUBLIC_SUI_CLOCK_ID=0x6

# ── Walrus Storage ────────────────────────────────────────────────────
# Testnet endpoints (switch to mainnet when ready):
NEXT_PUBLIC_WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# For Mainnet:
# NEXT_PUBLIC_WALRUS_PUBLISHER=https://publisher.walrus.space
# NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus.space

# ── AI Assistant (Optional Bonus) ──────────────────────────────────────
# Get your API key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
